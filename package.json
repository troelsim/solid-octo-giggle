{
  "name": "wind-farm-designer",
  "version": "0.1.0",
  "private": true,
  "description": "PadSketch — a mobile-first wind farm layout tool built with React and Leaflet",
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4",
    "zod": "^4.3.6"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src --ext .js --max-warnings 0",
    "lint:js:fix": "eslint src --ext .js --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "e2e": "playwright test",
    "screenshot": "playwright test e2e/screenshots.spec.js",
    "bdd": "cucumber-js --config cucumber.cjs",
    "bdd:report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "bdd:report:generate": "allure generate allure-results --clean -o allure-report"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/register": "^7.29.3",
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.2",
    "jest-environment-jsdom": "^30.3.0",
    "stylelint": "^17.8.0"
  }
}
